<?xml version="1.0" encoding="UTF-8"?>
<form xmlns="http://www.intellij.com/uidesigner/form/" version="1" bind-to-class="gui.gestionale.SelezioneTavoloSlotMachine">
  <grid id="27dc6" binding="selezioneTavoloPanel" layout-manager="GridLayoutManager" row-count="3" column-count="2" same-size-horizontally="false" same-size-vertically="false" hgap="-1" vgap="-1">
    <margin top="0" left="0" bottom="0" right="0"/>
    <constraints>
      <xy x="20" y="20" width="500" height="400"/>
    </constraints>
    <properties>
      <background color="-15923680"/>
    </properties>
    <border type="none"/>
    <children>
      <component id="35a0e" class="javax.swing.JButton" binding="tornaIndietroButton" default-binding="true">
        <constraints>
          <grid row="0" column="1" row-span="1" col-span="1" vsize-policy="0" hsize-policy="3" anchor="0" fill="1" indent="0" use-parent-layout="false"/>
        </constraints>
        <properties>
          <background color="-12772720"/>
          <foreground color="-10496"/>
          <text value="Torna Indietro"/>
        </properties>
      </component>
      <component id="bb459" class="javax.swing.JButton" binding="entraTavoloButton" default-binding="true">
        <constraints>
          <grid row="1" column="1" row-span="1" col-span="1" vsize-policy="0" hsize-policy="3" anchor="0" fill="1" indent="0" use-parent-layout="false"/>
        </constraints>
        <properties>
          <background color="-12772720"/>
          <foreground color="-10496"/>
          <text value="Entra Tavolo"/>
        </properties>
      </component>
      <component id="6bf3f" class="javax.swing.JList" binding="listaTavoli">
        <constraints>
          <grid row="2" column="0" row-span="1" col-span="1" vsize-policy="6" hsize-policy="2" anchor="0" fill="3" indent="0" use-parent-layout="false">
            <preferred-size width="150" height="50"/>
          </grid>
        </constraints>
        <properties>
          <background color="-15923680"/>
          <enabled value="true"/>
          <foreground color="-10496"/>
          <selectionBackground color="-12772720"/>
          <selectionForeground color="-10496"/>
        </properties>
      </component>
      <component id="4532d" class="javax.swing.JLabel" binding="selezioneListaLabel">
        <constraints>
          <grid row="2" column="1" row-span="1" col-span="1" vsize-policy="0" hsize-policy="0" anchor="1" fill="0" indent="0" use-parent-layout="false"/>
        </constraints>
        <properties>
          <background color="-15923680"/>
          <foreground color="-10496"/>
          <text value="Label"/>
        </properties>
      </component>
    </children>
  </grid>
</form>
